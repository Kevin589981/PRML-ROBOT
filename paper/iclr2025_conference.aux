\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces {\bfseries  Critical Failure Modes of MLP-Base.} While robust to physics, the policy collapses under temporal changes and execution noise (data extracted from Appendix).}}{9}{table.caption.7}\protected@file@percent }
\newlabel{tab:mlp_failure_modes}{{2}{9}{{\bfseries Critical Failure Modes of MLP-Base.} While robust to physics, the policy collapses under temporal changes and execution noise (data extracted from Appendix)}{table.caption.7}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces {\bfseries  Vision Policy Generalization (Vision-Final).} Success rates under varying degrees of perturbation across six dimensions. The vision-based policy demonstrates strong robustness to visual noise (Camera Pose, Basket Position) and physical friction, but degrades linearly with spatial distribution shift (Cube Range) and shows high sensitivity to action execution noise.}}{9}{figure.caption.8}\protected@file@percent }
\newlabel{fig:vision_eval}{{7}{9}{{\bfseries Vision Policy Generalization (Vision-Final).} Success rates under varying degrees of perturbation across six dimensions. The vision-based policy demonstrates strong robustness to visual noise (Camera Pose, Basket Position) and physical friction, but degrades linearly with spatial distribution shift (Cube Range) and shows high sensitivity to action execution noise}{figure.caption.8}{}}
\@writefile{toc}{\contentsline {subsubsection}{\numberline {4.1.3}Vision-Final Policy Generalization Analysis.}{9}{subsubsection.4.1.3}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces {\bfseries  Distribution Study: Training Distribution vs. Model Generalization.} Success rates on the fixed ``Hard'' baseline evaluation set when trained on datasets with varying randomization scales (limited to 100 demos). {\bfseries  (Top Left)} Inverse scaling in basket noise suggests lower training variance aids feature learning under data scarcity. \textbf  {(Top Right)} Direct scaling in spatial range confirms coverage is essential for geometric generalization. \textbf  {(Bottom)} A ``sweet spot'' in initial condition noise (20mm) balances visual servoing learning against data sparsity.}}{10}{figure.caption.9}\protected@file@percent }
\newlabel{fig:dist_study}{{8}{10}{{\bfseries Distribution Study: Training Distribution vs. Model Generalization.} Success rates on the fixed ``Hard'' baseline evaluation set when trained on datasets with varying randomization scales (limited to 100 demos). {\bfseries (Top Left)} Inverse scaling in basket noise suggests lower training variance aids feature learning under data scarcity. \textbf {(Top Right)} Direct scaling in spatial range confirms coverage is essential for geometric generalization. \textbf {(Bottom)} A ``sweet spot'' in initial condition noise (20mm) balances visual servoing learning against data sparsity}{figure.caption.9}{}}
